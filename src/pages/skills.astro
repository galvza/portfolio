---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ScrollReveal from '@/components/animations/ScrollReveal.astro';
import { getSkills } from '@/data/skills';
import { t } from '@/i18n/utils';

const locale = 'pt-br' as const;
const title = t('seo.skillsTitle', locale);
const description = t('seo.skillsDescription', locale);
const categories = getSkills(locale);
---

<BaseLayout {title} {description} {locale}>
  <div class="container section">

    <ScrollReveal direction="up" delay={0}>
      <h1 class="mb-16">{t('skills.title', locale)}</h1>
    </ScrollReveal>

    <div class="flex flex-col gap-14">
      {categories.map((category, i) => (
        <ScrollReveal direction="up" delay={0.05 * i}>
          <section aria-labelledby={`skill-${category.id}`}>
            <h2
              id={`skill-${category.id}`}
              class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-5 pb-3 border-b border-border"
            >
              {t(category.labelKey, locale)}
            </h2>
            <ul class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap" role="list">
              {category.skills.map((skill) => (
                <li>
                  <span class="inline-flex items-center justify-center w-full sm:w-auto px-4 py-2.5 text-sm font-medium font-mono bg-bg-alt border border-border text-text hover:border-accent hover:text-accent transition-colors">
                    {skill}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        </ScrollReveal>
      ))}
    </div>

  </div>
</BaseLayout>
