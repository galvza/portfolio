---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Timeline from '@/components/career/Timeline.astro';
import CertificationCard from '@/components/career/CertificationCard.astro';
import ScrollReveal from '@/components/animations/ScrollReveal.astro';
import { getCertifications, getEducation } from '@/data/career';
import { getSkills } from '@/data/skills';
import { t } from '@/i18n/utils';

const locale = 'pt-br' as const;
const title = t('seo.aboutTitle', locale);
const description = t('seo.aboutDescription', locale);
const certifications = getCertifications(locale);
const education = getEducation(locale);
const skillCategories = getSkills(locale);

const certCategories = ['about.certDataBI', 'about.certPython', 'about.certFrontend'] as const;
---

<BaseLayout {title} {description} {locale}>
  <div class="container section">

    <ScrollReveal direction="up" delay={0}>
      <h1 class="mb-16">{t('about.title', locale)}</h1>
    </ScrollReveal>

    {/* ── Bio ── */}
    <section class="mb-20">
      <ScrollReveal direction="up">
        <div class="prose-section max-w-3xl space-y-5 text-text-muted leading-relaxed">
          <p>Comecei no administrativo em 2019. Me destaquei pela comunicação e agilidade, e rapidamente migrei pro comercial e marketing. Como Gerente Comercial, transformei o posicionamento digital da empresa, tornando o WhatsApp o principal canal de vendas — superando a loja física. Desenvolvi uma nova versão do site do zero e implementei processos que antes não existiam.</p>
          <p>Como gosto de desafios, no mesmo período me dedicava a aprender sobre marketing digital. Foi onde iniciei minhas operações em tráfego pago e copywriting, descobrindo que sabia transformar dados de campanha em decisões com resultado real. Essa paixão por performance me levou a operar campanhas de Meta Ads em escala — orçamentos de 6 dígitos/mês com ROI consistente.</p>
          <p>Mas o que eu mais gostava não era criar anúncios — era analisar o que funcionava e por quê.</p>
          <p>Sou formado em Análise e Desenvolvimento de Sistemas, com curso técnico em Informática. Essa base me deu o que muitos analistas não têm: eu não só analiso dados, eu construo as ferramentas. Python, SQL, automações com N8N, dashboards interativos, sites completos — se resolve um problema, eu aprendo e faço.</p>
          <p>Os projetos deste portfólio são o resultado — construídos do zero, com dados reais, pipelines automatizados e interfaces interativas. Minha vantagem? Sou multifunções. Entendo o negócio, analiso os dados e construo a solução.</p>
        </div>
      </ScrollReveal>
    </section>

    {/* ── Timeline ── */}
    <section class="mb-20" aria-labelledby="career-heading">
      <ScrollReveal direction="up">
        <h2 id="career-heading" class="mb-10">{t('about.careerTitle', locale)}</h2>
      </ScrollReveal>
      <Timeline {locale} />
    </section>

    {/* ── Education ── */}
    <section class="mb-20" aria-labelledby="education-heading">
      <ScrollReveal direction="up">
        <h2 id="education-heading" class="mb-10">{t('about.educationTitle', locale)}</h2>
      </ScrollReveal>
      <ScrollReveal direction="up" delay={0.1}>
        <div class="grid gap-4 sm:grid-cols-2">
          {education.map((edu) => (
            <div class="border border-border bg-bg-alt p-5 hover:border-accent transition-colors group">
              <p class="font-medium text-text group-hover:text-accent transition-colors mb-1">{edu.degree}</p>
              <p class="text-sm text-text-muted">{edu.institution}</p>
              <p class="text-xs font-mono text-text-muted mt-2">{edu.year}</p>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </section>

    {/* ── Skills ── */}
    <section class="mb-20" aria-labelledby="skills-heading">
      <ScrollReveal direction="up">
        <h2 id="skills-heading" class="mb-10">{t('about.skills', locale)}</h2>
      </ScrollReveal>
      <ScrollReveal direction="up" delay={0.1} stagger={0.1}>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {skillCategories.map(({ labelKey, skills }) => (
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-4">
                {t(labelKey, locale)}
              </h3>
              <ul class="flex flex-wrap gap-2" role="list">
                {skills.map((skill) => (
                  <li>
                    <span class="inline-block px-2.5 py-1 text-xs font-medium font-mono bg-bg-alt border border-border text-text-muted">
                      {skill}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </ScrollReveal>
    </section>

    {/* ── Certifications ── */}
    <section aria-labelledby="certs-heading">
      <ScrollReveal direction="up">
        <h2 id="certs-heading" class="mb-10">{t('about.certificationsTitle', locale)}</h2>
      </ScrollReveal>

      {certCategories.map((catKey) => {
        const catCerts = certifications.filter((c) => c.category === catKey);
        return (
          <div class="mb-8 last:mb-0">
            <ScrollReveal direction="up">
              <h3 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-4">
                {t(catKey, locale)}
              </h3>
            </ScrollReveal>
            <ScrollReveal direction="up" stagger={0.05}>
              <ul
                class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"
                role="list"
              >
                {catCerts.map((cert) => (
                  <li>
                    <CertificationCard name={cert.name} platform={cert.platform} year={cert.year} />
                  </li>
                ))}
              </ul>
            </ScrollReveal>
          </div>
        );
      })}
    </section>

  </div>
</BaseLayout>
