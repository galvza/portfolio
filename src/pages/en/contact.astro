---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/contact/ContactForm.astro';
import { t } from '@/i18n/utils';

const locale = 'en' as const;
const title = t('seo.contactTitle', locale);
const description = t('seo.contactDescription', locale);
---

<BaseLayout {title} {description} {locale}>
  <div class="container section">

    <div class="lg:grid lg:grid-cols-[1fr_360px] lg:gap-16 xl:grid-cols-[1fr_400px]">

      {/* Form */}
      <div>
        <h1 class="mb-4">{t('contact.title', locale)}</h1>
        <p class="text-text-muted text-lg mb-10 max-w-md">
          Have a project, a question, or just want to chat? Send a message.
        </p>
        <ContactForm {locale} />
      </div>

      {/* Alternative channels */}
      <aside class="mt-14 lg:mt-0 lg:pt-20">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-6">
          {t('contact.alternativeChannels', locale)}
        </h2>
        <ul class="flex flex-col gap-4" role="list">

          <li>
            <a
              href="https://linkedin.com/in/biel-als/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-sm text-text-muted hover:text-accent transition-colors group"
            >
              <span class="w-9 h-9 flex items-center justify-center border border-border group-hover:border-accent transition-colors flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </span>
              <span>LinkedIn</span>
            </a>
          </li>

          <li>
            <a
              href="https://github.com/galvza"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-sm text-text-muted hover:text-accent transition-colors group"
            >
              <span class="w-9 h-9 flex items-center justify-center border border-border group-hover:border-accent transition-colors flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
              </span>
              <span>GitHub</span>
            </a>
          </li>

          <li>
            <a
              data-email-user="gabriel"
              data-email-domain="gsdigitais.com"
              href="#"
              class="flex items-center gap-3 text-sm text-text-muted hover:text-accent transition-colors group"
            >
              <span class="w-9 h-9 flex items-center justify-center border border-border group-hover:border-accent transition-colors flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </span>
              <span data-email-text>E-mail</span>
            </a>
          </li>

        </ul>
      </aside>

    </div>

  </div>
</BaseLayout>
