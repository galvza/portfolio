---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import ProjectPreview from '@/components/home/ProjectPreview.astro';
import ServicesSection from '@/components/home/ServicesSection.astro';
import BlogPreview from '@/components/home/BlogPreview.astro';
import CTASection from '@/components/home/CTASection.astro';
import { t } from '@/i18n/utils';

const locale = 'en' as const;
const title = t('seo.homeTitle', locale);
const description = t('seo.homeDescription', locale);
---

<BaseLayout {title} {description} {locale}>
  <HeroSection {locale} />
  <div class="bg-bg-alt">
    <ProjectPreview {locale} />
  </div>
  <ServicesSection {locale} />
  <div class="bg-bg-alt">
    <BlogPreview {locale} />
  </div>
  <div class="bg-bg-alt">
    <CTASection {locale} />
  </div>
</BaseLayout>
