---
import { t, getLocalizedPath } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const contactHref = getLocalizedPath('/contato', locale);
---

<section class="overflow-hidden">
  <div class="container section">
    <div class="flex flex-col gap-10 text-center lg:grid lg:grid-cols-2 lg:items-center lg:gap-16 lg:text-left">

      {/* Coluna esquerda: texto + CTAs */}
      <div class="flex flex-col items-center gap-8 lg:items-start">

        {/* Headline */}
        <h1 data-scroll-reveal='{"direction":"up","delay":0,"duration":0.8}'>
          {t('home.headline', locale)}
        </h1>

        {/* Bio */}
        <p
          data-scroll-reveal='{"direction":"up","delay":0.15,"duration":0.7}'
          class="max-w-xl text-text-muted"
        >
          {t('home.bio', locale)}
        </p>

        {/* CTAs */}
        <div
          data-scroll-reveal='{"direction":"up","delay":0.28,"duration":0.6}'
          class="flex flex-col items-center gap-4 w-full sm:flex-row sm:justify-center lg:justify-start"
        >
          <a
            href={contactHref}
            data-track="click_contact"
            class="inline-flex items-center justify-center h-12 px-8 bg-accent text-white font-medium text-sm hover:bg-accent-hover transition-colors w-full sm:w-auto"
          >
            {t('home.ctaContact', locale)}
          </a>

          <div class="flex items-center gap-6">
            <a
              href="https://linkedin.com/in/biel-als/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-text-muted hover:text-text transition-colors underline-offset-4 hover:underline"
            >
              LinkedIn
            </a>
            <a
              href="https://github.com/galvza"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-text-muted hover:text-text transition-colors underline-offset-4 hover:underline"
            >
              GitHub
            </a>
          </div>
        </div>

      </div>

      {/* Foto mobile: centralizada, sem corte estranho */}
      <div
        data-scroll-reveal='{"direction":"up","delay":0.1,"duration":0.8}'
        class="w-full h-[350px] overflow-hidden lg:hidden"
      >
        <img
          src="/images/gabriel.png"
          alt="Gabriel Alves de Souza"
          width="460"
          height="460"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover object-top grayscale opacity-60 scale-110"
        />
      </div>

      {/* Foto desktop: cortada pela borda direita */}
      <div
        data-scroll-reveal='{"direction":"up","delay":0.1,"duration":0.8}'
        class="hidden lg:block relative h-[500px] xl:h-[600px] -mr-[40%] overflow-hidden"
      >
        <img
          src="/images/gabriel.png"
          alt="Gabriel Alves de Souza"
          width="460"
          height="460"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover object-[30%_15%] grayscale opacity-60 scale-125"
        />
      </div>

    </div>
  </div>
</section>
