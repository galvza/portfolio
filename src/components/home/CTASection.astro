---
import type { Locale } from '@/i18n/config';
import { t, getLocalizedPath } from '@/i18n/utils';
import ScrollReveal from '@/components/animations/ScrollReveal.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const contactHref = getLocalizedPath('/contato', locale);
---

<section class="section" aria-labelledby="cta-section-heading">
  <div class="container">
    <ScrollReveal direction="up">

      <div class="border-t border-border pt-16 text-center lg:pt-24">

        {/* Label superior — tom editorial */}
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-text-muted mb-4">
          {locale === 'en' ? 'Work together' : 'Trabalhe comigo'}
        </p>

        {/* Headline — sem max-w para compartilhar o mesmo eixo central do label */}
        <h2
          id="cta-section-heading"
          class="font-heading font-bold text-center text-4xl leading-none md:text-6xl lg:text-7xl mb-6"
        >
          {t('home.ctaHeadline', locale)}
        </h2>

        <p class="text-lg text-text-muted max-w-md mx-auto mb-10">
          {t('home.ctaSubtext', locale)}
        </p>

        {/* CTAs empilhados: botão primário → separador → links secundários */}
        <div class="flex flex-col items-center gap-4">

          {/* CTA primário */}
          <a
            href={contactHref}
            data-track="click_contact"
            class="inline-flex items-center justify-center h-14 px-16 text-lg bg-accent text-white font-medium hover:bg-accent-hover transition-colors w-full sm:w-auto"
          >
            {t('home.ctaContact', locale)}
          </a>

          {/* Separador sutil */}
          <span class="text-sm text-text-muted" aria-hidden="true">
            {locale === 'en' ? 'or' : 'ou'}
          </span>

          {/* Links secundários — touch target ≥ 44px via h-11 */}
          <div class="flex items-center gap-6">
            <a
              href="https://linkedin.com/in/biel-als/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center h-11 px-2 text-sm text-text-muted underline underline-offset-4 hover:text-text transition-colors"
            >
              LinkedIn
            </a>
            <a
              data-email-user="gabriel"
              data-email-domain="gsdigitais.com"
              href="#"
              class="inline-flex items-center h-11 px-2 text-sm text-text-muted underline underline-offset-4 hover:text-text transition-colors"
            >
              {t('home.ctaEmail', locale)}
            </a>
          </div>

        </div>
      </div>

    </ScrollReveal>
  </div>
</section>
