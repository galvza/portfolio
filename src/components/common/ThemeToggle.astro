---
import { t } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  aria-label={t('common.darkMode', locale)}
  data-label-dark={t('common.darkMode', locale)}
  data-label-light={t('common.lightMode', locale)}
  class="flex items-center justify-center w-11 h-11 rounded-md text-text-muted transition-colors hover:text-text hover:bg-bg-alt"
>
  {/* Ícone sol — visível no dark mode (clicar vai para light) */}
  <svg
    class="sun-icon hidden"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>

  {/* Ícone lua — visível no light mode (clicar vai para dark) */}
  <svg
    class="moon-icon"
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  import { toggleTheme, setupSystemThemeListener } from '@/scripts/theme';

  function syncToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const isDark = document.documentElement.classList.contains('dark');
    const sun = btn.querySelector<SVGElement>('.sun-icon');
    const moon = btn.querySelector<SVGElement>('.moon-icon');

    // No dark mode: mostra sol (vai para light), esconde lua
    if (sun) sun.classList.toggle('hidden', !isDark);
    if (moon) moon.classList.toggle('hidden', isDark);

    // aria-label: descreve a ação que o botão vai executar
    const labelDark = btn.getAttribute('data-label-dark') ?? 'Dark mode';
    const labelLight = btn.getAttribute('data-label-light') ?? 'Light mode';
    btn.setAttribute('aria-label', isDark ? labelLight : labelDark);
  }

  function initToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.themeInit) return;
    btn.dataset.themeInit = 'true';

    btn.addEventListener('click', () => {
      toggleTheme();
      syncToggle();
      // Plausible event
      const newTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      if (typeof window.plausible === 'function') {
        window.plausible('switch_theme', { props: { to: newTheme } });
      }
    });

    // Sincroniza ícone com o tema atual (já aplicado pelo script anti-flash ou astro:before-swap)
    syncToggle();
  }

  // Re-inicializa o botão em cada navegação (View Transitions substitui o elemento DOM)
  document.addEventListener('astro:page-load', initToggle);

  // Fallback: Safari iOS nem sempre dispara astro:page-load na primeira carga.
  // Usa data-attribute pra evitar dupla inicialização se ambos dispararem.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToggle);
  } else {
    initToggle();
  }

  // Acompanha mudanças no prefers-color-scheme — registrado uma vez, persiste entre navegações.
  // syncToggle usa document.getElementById, então sempre encontra o botão atual.
  setupSystemThemeListener(syncToggle);
</script>
