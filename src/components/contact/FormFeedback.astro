---
interface Props {
  successMessage: string;
  errorMessage: string;
  sendAnotherLabel: string;
}

const { successMessage, errorMessage, sendAnotherLabel } = Astro.props;
---

{/* Success panel */}
<div id="feedback-success" hidden>
  <div class="flex items-start gap-3 p-5 border border-green-500/40 bg-green-500/10 feedback-panel">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-green-500 flex-shrink-0 mt-0.5"
      aria-hidden="true"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <div>
      <p class="font-medium text-text mb-3">{successMessage}</p>
      <button
        id="btn-send-another"
        type="button"
        class="text-sm text-accent hover:text-accent-hover underline underline-offset-2 transition-colors"
      >
        {sendAnotherLabel}
      </button>
    </div>
  </div>
</div>

{/* Error panel */}
<div id="feedback-error" hidden>
  <div class="flex items-start gap-3 p-5 border border-red-500/40 bg-red-500/10 feedback-panel">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-red-500 flex-shrink-0 mt-0.5"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="12"></line>
      <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </svg>
    <p class="font-medium text-text">{errorMessage}</p>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .feedback-panel {
      animation: feedback-slide-in 0.2s ease;
    }
  }

  @keyframes feedback-slide-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
