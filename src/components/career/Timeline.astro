---
import TimelineItem from './TimelineItem.astro';
import { getTimeline } from '@/data/career';
import type { Locale } from '@/i18n/config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const entries = getTimeline(locale);
---

{/*
  Vertical timeline — left-aligned on both mobile and desktop.
  Line at left-4 (16px); dot centers on it.
  Desktop: wider spacing (pl-14) and larger type (via TimelineItem).
  P-16 will target [data-animate="timeline-item"] for scroll reveal.
*/}
<div class="relative">

  {/* Vertical line */}
  <div
    class="absolute left-4 top-2 bottom-0 w-px bg-border"
    aria-hidden="true"
  ></div>

  <ol class="list-none m-0 p-0" role="list">
    {entries.map((entry) => (
      <TimelineItem {entry} {locale} />
    ))}
  </ol>

</div>
