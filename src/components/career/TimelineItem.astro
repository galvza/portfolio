---
import { t } from '@/i18n/utils';
import type { Locale } from '@/i18n/config';
import type { TimelineEntry } from '@/data/career';

interface Props {
  entry: TimelineEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
---

<li
  class="relative pl-10 pb-12 last:pb-0 lg:pl-14 lg:pb-16"
  data-animate="timeline-item"
>
  {/* Dot — centered on the vertical line (line at left-4=16px, dot w-3=12px → left-[10px]) */}
  <div
    class="absolute left-[10px] top-[5px] w-3 h-3 rounded-full bg-accent border-2 border-bg
           lg:left-[14px] lg:top-[6px] lg:w-4 lg:h-4"
    aria-hidden="true"
  ></div>

  {/* Period */}
  <span class="block text-xs font-mono uppercase tracking-widest text-text-muted mb-1">
    {entry.period}
  </span>

  {/* Role */}
  <h3 class="text-xl font-bold leading-tight mb-0.5 lg:text-2xl">
    {entry.role}
  </h3>

  {/* Company */}
  <p class="text-accent text-sm font-medium mb-3">{entry.company}</p>

  {/* Description */}
  <p class="text-text-muted text-sm leading-relaxed mb-4 lg:max-w-xl lg:text-base">
    {entry.description}
  </p>

  {/* Achievements — renderiza apenas se houver itens */}
  {entry.achievements.length > 0 && (
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-text-muted mb-2">
        {t('about.achievements', locale)}
      </p>
      <ul class="flex flex-col gap-2" role="list">
        {entry.achievements.map((achievement) => (
          <li class="flex items-start gap-2 text-sm lg:text-sm">
            <span class="text-accent mt-0.5 flex-shrink-0 font-mono leading-none" aria-hidden="true">→</span>
            <span class="text-text-muted">{achievement}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</li>
