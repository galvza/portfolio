---
interface Props {
  name: string;
  platform: string;
  year: string;
}

const { name, platform, year } = Astro.props;
---

<div class="border border-border bg-bg-alt p-4 flex flex-col gap-3 hover:border-accent transition-colors group">
  <p class="text-sm font-medium leading-tight group-hover:text-accent transition-colors">
    {name}
  </p>
  <div class="flex items-center justify-between mt-auto">
    <span class="text-xs font-mono text-text-muted">{platform}</span>
    <span class="text-xs font-mono text-text-muted">{year}</span>
  </div>
</div>
