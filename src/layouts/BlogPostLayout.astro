---
import '@/styles/prose.css';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReadingTime from '@/components/blog/ReadingTime.astro';
import { t } from '@/i18n/utils';
import { formatLocalizedDate } from '@/utils/dates';
import { calculateReadingTime } from '@/utils/reading-time';
import type { Locale } from '@/i18n/config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  locale: Locale;
  prev?: CollectionEntry<'blog'> | null;
  next?: CollectionEntry<'blog'> | null;
}

const { post, locale, prev, next } = Astro.props;
const { title, description, date, updatedDate, tags } = post.data;

const listingHref = locale === 'en' ? '/en/blog' : '/blog';
const formattedDate = formatLocalizedDate(date, locale);
const formattedUpdated = updatedDate ? formatLocalizedDate(updatedDate, locale) : null;
const readingMinutes = calculateReadingTime(post.body ?? '');

function postHref(entry: CollectionEntry<'blog'>): string {
  const slug = entry.id.split('/')[0];
  return locale === 'en' ? `/en/blog/${slug}` : `/blog/${slug}`;
}
---

<BaseLayout {title} {description} {locale} type="article" publishedTime={date} {tags} image={post.data.image}>

  <article class="container py-12 lg:py-20">

    {/* Back link — não indexado (fora do data-pagefind-body) */}
    <a
      href={listingHref}
      class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors mb-10"
    >
      ← {t('common.allPosts', locale)}
    </a>

    {/* Post header — não indexado (fora do data-pagefind-body) */}
    <header class="mb-10 max-w-[65ch]">
      <h1 class="mb-6">{title}</h1>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-muted">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {formattedUpdated && (
          <span>
            {t('blog.updatedOn', locale).replace('{date}', formattedUpdated)}
          </span>
        )}
        <span aria-hidden="true">·</span>
        <ReadingTime minutes={readingMinutes} {locale} />
      </div>

      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-4" role="list">
          {tags.map((tag) => (
            <li>
              <span class="inline-block px-2 py-0.5 text-xs font-medium bg-bg-alt border border-border text-text-muted">
                {tag}
              </span>
            </li>
          ))}
        </ul>
      )}
    </header>

    {/* MDX content — único elemento indexado pelo Pagefind */}
    <div class="prose" data-pagefind-body>
      {/* Filtro de idioma — precisa estar dentro de data-pagefind-body */}
      <span hidden data-pagefind-filter={`language[${locale}]`}></span>
      <slot />
    </div>

    {/* Prev / Next navigation */}
    {(prev || next) && (
      <nav
        aria-label={locale === 'en' ? 'Post navigation' : 'Navegação entre posts'}
        class="mt-16 pt-8 border-t border-border grid grid-cols-2 gap-4"
      >
        <div class="min-w-0">
          {prev && (
            <a
              href={postHref(prev)}
              class="group flex flex-col gap-1 text-sm"
            >
              <span class="text-text-muted">{t('common.previousPost', locale)}</span>
              <span class="font-medium group-hover:text-accent transition-colors line-clamp-2">
                ← {prev.data.title}
              </span>
            </a>
          )}
        </div>
        <div class="min-w-0 text-right">
          {next && (
            <a
              href={postHref(next)}
              class="group flex flex-col gap-1 text-sm items-end"
            >
              <span class="text-text-muted">{t('common.nextPost', locale)}</span>
              <span class="font-medium group-hover:text-accent transition-colors line-clamp-2">
                {next.data.title} →
              </span>
            </a>
          )}
        </div>
      </nav>
    )}

  </article>

</BaseLayout>
